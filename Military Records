function nv(id){const v=document.getElementById(id)?.value?.replace(/,/g,'').trim();return v?(parseFloat(v)||0):0;}
function p(s){if(!s&&s!==0)return 0;return parseFloat(String(s).replace(/,/g,''))||0;}
function fmt(n){n=p(n);const a=Math.abs(n);if(a>=1e15)return(n/1e15).toFixed(2)+'Q';if(a>=1e12)return(n/1e12).toFixed(2)+'T';if(a>=1e9)return(n/1e9).toFixed(2)+'B';if(a>=1e6)return(n/1e6).toFixed(2)+'M';if(a>=1e3)return(n/1e3).toFixed(1)+'K';return Math.round(n).toLocaleString();}
function fmtD(n){return(n>=0?'+':'')+fmt(n);}

function computed(snap){
  if(!snap)return{};
  return{...snap,
    mercsKilled:p(snap.atkMercsKilled)+p(snap.defMercsKilled),
    soldiersKilled:p(snap.atkSoldiersKilled)+p(snap.defSoldiersKilled),
    superSoldiersKilled:p(snap.atkSSKilled)+p(snap.defSSKilled),
    totalKilled:p(snap.atkMercsKilled)+p(snap.defMercsKilled)+p(snap.atkSoldiersKilled)+p(snap.defSoldiersKilled)+p(snap.atkSSKilled)+p(snap.defSSKilled)+p(snap.spiesKilled)+p(snap.spyKillersKilled),
    totalRaided:p(snap.uuRaided),
    planetsNet:p(snap.planetsTaken)-p(snap.planetsLost),
  };
}

function getDelta(name,cat,period){
  const snaps=db.snapshots[name]||[];
  if(snaps.length<2)return null;
  const latest=computed(snaps[snaps.length-1]);
  let base;
  if(period==='last')base=computed(snaps[snaps.length-2]);
  else if(period==='all')base=computed(snaps[0]);
  else{const idx=Math.max(0,snaps.length-1-parseInt(period));base=computed(snaps[idx]);}
  return p(latest[cat]||0)-p(base[cat]||0);
}

