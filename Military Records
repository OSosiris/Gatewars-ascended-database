
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0c10;--bg2:#0f1218;--bg3:#151a22;--bg4:#1c2330;
  --border:#2a3548;--border2:#3a4f6a;
  --text:#c8d8e8;--text2:#7a9ab8;--text3:#4a6a8a;
  --gold:#f0c040;--silver:#b0bec5;--bronze:#cd7f32;
  --accent:#4a9eff;--accent2:#2a6eba;
  --red:#ff4a4a;--green:#4aff8a;--green2:#1a5a3a;
  --mono:'Share Tech Mono',monospace;--head:'Rajdhani',sans-serif;
}
body{background:var(--bg);color:var(--text);font-family:var(--mono);font-size:13px;}
.app{padding:1rem;}
.header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid var(--border);}
.alliance-label{font-size:10px;color:var(--text3);letter-spacing:.12em;text-transform:uppercase;font-family:var(--head);}
.alliance-name{font-size:22px;font-weight:700;color:#fff;font-family:var(--head);letter-spacing:.04em;}
.member-badge{background:var(--bg4);border:1px solid var(--border2);color:var(--accent);font-size:11px;padding:3px 10px;border-radius:2px;font-family:var(--head);letter-spacing:.06em;}
.tabs{display:flex;border-bottom:1px solid var(--border);margin-bottom:1.5rem;overflow-x:auto;}
.tab{padding:8px 16px;font-size:12px;cursor:pointer;border:none;background:none;color:var(--text3);border-bottom:2px solid transparent;margin-bottom:-1px;font-family:var(--head);letter-spacing:.05em;text-transform:uppercase;font-weight:600;transition:color .15s;white-space:nowrap;}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.tab.weekly-tab.active{color:var(--green);border-bottom-color:var(--green);}
.tab:hover:not(.active){color:var(--text);}
.panel{display:none;}.panel.active{display:block;}
.btn{padding:6px 14px;font-size:12px;border:1px solid var(--border2);border-radius:2px;background:transparent;color:var(--text);cursor:pointer;font-family:var(--head);letter-spacing:.06em;font-weight:600;text-transform:uppercase;transition:all .15s;}
.btn:hover{background:var(--bg4);border-color:var(--accent);color:var(--accent);}
.btn.primary{background:var(--accent2);border-color:var(--accent);color:#fff;}
.btn.primary:hover{background:var(--accent);color:#000;}
.btn.success{background:var(--green2);border-color:var(--green);color:var(--green);}
.btn.success:hover{background:#1a7a4a;}
.btn.danger{border-color:#a33;color:#f88;}
.btn.danger:hover{background:#300;border-color:var(--red);color:var(--red);}
.btn-sm{padding:3px 10px;font-size:11px;}
input,select,textarea{font-family:var(--mono);font-size:12px;color:var(--text);background:var(--bg3);border:1px solid var(--border);border-radius:2px;padding:6px 10px;width:100%;outline:none;transition:border-color .15s;}
input:focus,select:focus,textarea:focus{border-color:var(--border2);color:#fff;}
textarea{resize:vertical;line-height:1.5;}
select option{background:var(--bg3);}
label{font-size:11px;color:var(--text3);display:block;margin-bottom:3px;font-family:var(--head);letter-spacing:.05em;text-transform:uppercase;}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:3px;padding:1rem 1.25rem;}
.metric{background:var(--bg3);border:1px solid var(--border);border-radius:2px;padding:.75rem 1rem;}
.metric .mlabel{font-size:10px;color:var(--text3);margin-bottom:4px;font-family:var(--head);letter-spacing:.08em;text-transform:uppercase;}
.metric .mvalue{font-size:18px;font-weight:700;color:#fff;font-family:var(--head);}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
table{width:100%;border-collapse:collapse;font-size:12px;}
th{text-align:left;padding:8px 12px;font-size:10px;font-weight:700;color:var(--text3);border-bottom:1px solid var(--border);font-family:var(--head);letter-spacing:.1em;text-transform:uppercase;}
td{padding:9px 12px;border-bottom:1px solid var(--border);color:var(--text);}
tr:last-child td{border-bottom:none;}
tr.data-row:hover td{background:var(--bg3);cursor:pointer;}
.num{text-align:right;font-variant-numeric:tabular-nums;color:#fff;}
.rank-medal{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;font-size:12px;font-weight:700;font-family:var(--head);}
.medal-1{background:#c89000;color:#3a2000;}
.medal-2{background:#8090a0;color:#1a2030;}
.medal-3{background:#8b5010;color:#2a1000;}
.medal-n{background:var(--bg4);color:var(--text3);border:1px solid var(--border);}
.medal-0w{background:#1a5a3a;color:var(--green);border:1px solid var(--green);}
.medal-1w{background:#1a3a5a;color:#88ccff;border:1px solid #4a9eff;}
.medal-2w{background:#3a2a1a;color:#ffcc88;border:1px solid #cd7f32;}
.section-title{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;font-family:var(--head);}
.divider{border:none;border-top:1px solid var(--border);margin:1rem 0;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.form-group{display:flex;flex-direction:column;gap:3px;}
.delta-pos{color:var(--green);font-size:11px;}
.delta-neg{color:var(--red);font-size:11px;}
.modal-bg{display:none;min-height:600px;background:rgba(0,0,0,.78);align-items:flex-start;justify-content:center;padding:2rem 1rem;}
.modal-bg.open{display:flex;}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:3px;padding:1.5rem;width:min(560px,96vw);max-height:85vh;overflow-y:auto;}
.modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;padding-bottom:.75rem;border-bottom:1px solid var(--border);}
.modal-title{font-size:18px;font-weight:700;color:#fff;font-family:var(--head);letter-spacing:.04em;}
.modal-close{background:none;border:none;font-size:22px;cursor:pointer;color:var(--text3);padding:2px 6px;line-height:1;}
.modal-close:hover{color:var(--red);}
.empty{text-align:center;padding:2.5rem;color:var(--text3);font-family:var(--head);letter-spacing:.06em;}
.snap-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:12px;}
.snap-row:last-child{border-bottom:none;}
.progress-wrap{height:3px;background:var(--bg4);border-radius:2px;overflow:hidden;margin-top:4px;}
.progress-fill{height:100%;border-radius:2px;}
.parse-preview{background:var(--bg4);border:1px solid var(--border2);border-radius:2px;padding:.75rem 1rem;margin-top:.75rem;font-size:11px;line-height:1.8;}
.pk{color:var(--text3);}
.pv{color:var(--green);font-weight:700;}
.parsed-field{display:flex;justify-content:space-between;gap:8px;}
.inactive-badge{display:inline-block;padding:2px 8px;border-radius:2px;font-size:10px;font-family:var(--head);font-weight:700;letter-spacing:.06em;background:#2a1a1a;border:1px solid #a33;color:#f88;}
.active-badge{display:inline-block;padding:2px 8px;border-radius:2px;font-size:10px;font-family:var(--head);font-weight:700;letter-spacing:.06em;background:var(--green2);border:1px solid var(--green);color:var(--green);}
</style>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">

<div class="app">
<div class="header">
  <div>
    <div class="alliance-label">alliance command</div>
    <div class="alliance-name" id="alliance-name-display">THE RELENTLESS</div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;">
    <span class="member-badge" id="member-count-badge">0 MEMBERS</span>
    <button class="btn btn-sm" onclick="openSettings()">CONFIG</button>
  </div>
</div>

<div class="tabs">
  <button class="tab weekly-tab active" onclick="switchTab('weekly')">⚡ WEEKLY</button>
  <button class="tab" onclick="switchTab('leaderboard')">ALL-TIME</button>
  <button class="tab" onclick="switchTab('members')">MEMBERS</button>
  <button class="tab" onclick="switchTab('add')">+ ADD / UPDATE</button>
</div>

<div class="panel active" id="panel-weekly">
  <div style="display:flex;gap:8px;margin-bottom:1rem;flex-wrap:wrap;align-items:flex-end;">
    <div style="flex:1;min-width:180px;">
      <label>category</label>
      <select id="wk-category" onchange="renderWeekly()">
        <option value="warPoints">TOTAL WAR XP GAINED</option>
        <option value="totalKilled">TOTAL UNITS KILLED</option>
        <option value="totalRaided">TOTAL UNITS RAIDED</option>
        <option value="superSoldiersKilled">SUPER SOLDIERS KILLED</option>
        <option value="soldiersKilled">SOLDIERS KILLED</option>
        <option value="mercsKilled">MERCS KILLED</option>
        <option value="spiesKilled">SPIES KILLED</option>
        <option value="naqStolen">NAQUADAH STOLEN</option>
        <option value="planetsTaken">PLANETS TAKEN</option>
        <option value="wpDestroyed">WEAPON POINTS DESTROYED</option>
      </select>
    </div>
    <div style="min-width:160px;">
      <label>period</label>
      <select id="wk-period" onchange="renderWeekly()">
        <option value="last">latest vs previous</option>
        <option value="2">last 2 snapshots</option>
        <option value="4">last 4 snapshots</option>
        <option value="all">all-time growth</option>
      </select>
    </div>
  </div>
  <div class="card" style="padding:0;overflow:hidden;margin-bottom:1.5rem;">
    <div id="wk-table-container"><div class="empty">LOADING...</div></div>
  </div>
  <div>
    <p class="section-title">this period — alliance totals</p>
    <div class="grid4" id="wk-totals"></div>
  </div>
</div>

<div class="panel" id="panel-leaderboard">
  <div style="margin-bottom:1rem;">
    <select id="lb-category" onchange="renderLeaderboard()">
      <option value="warPoints">TOTAL WAR EXPERIENCE POINTS</option>
      <option value="totalKilled">TOTAL UNITS KILLED</option>
      <option value="totalRaided">TOTAL UNITS RAIDED</option>
      <option value="superSoldiersKilled">SUPER SOLDIERS KILLED</option>
      <option value="soldiersKilled">SOLDIERS KILLED</option>
      <option value="mercsKilled">MERCS KILLED</option>
      <option value="spiesKilled">SPIES KILLED</option>
      <option value="naqStolen">NAQUADAH STOLEN</option>
      <option value="planetsTaken">PLANETS TAKEN</option>
      <option value="planetsNet">PLANETS NET</option>
      <option value="wpDestroyed">WEAPON POINTS DESTROYED</option>
      <option value="naqLost">NAQUADAH LOST</option>
    </select>
  </div>
  <div class="card" style="padding:0;overflow:hidden;margin-bottom:1.5rem;">
    <div id="lb-table-container"><div class="empty">LOADING...</div></div>
  </div>
  <div>
    <p class="section-title">alliance totals (latest snapshots)</p>
    <div class="grid4" id="alliance-totals"></div>
  </div>
</div>

<div class="panel" id="panel-members">
  <div style="display:flex;gap:8px;margin-bottom:1rem;">
    <input type="text" id="member-search" placeholder="SEARCH PLAYERS..." oninput="renderMembers()" style="flex:1;">
    <button class="btn" onclick="switchTab('add')">+ ADD</button>
  </div>
  <div id="members-list"></div>
</div>

<div class="panel" id="panel-add">
  <div class="card" style="margin-bottom:10px;border-color:var(--accent2);">
    <p class="section-title" style="color:var(--accent);">paste ME — auto parse</p>
    <div style="display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap;">
      <div class="form-group" style="flex:1;min-width:160px;">
        <label>player name *</label>
        <input type="text" id="f-name" placeholder="e.g. Jedi Tank">
      </div>
      <div class="form-group" style="min-width:140px;">
        <label>snapshot date *</label>
        <input type="date" id="f-date">
      </div>
    </div>
    <div class="form-group">
      <label>paste full ME text here</label>
      <textarea id="paste-area" rows="6" placeholder="Paste everything from your ME page — labels and numbers..." oninput="parsePaste()"></textarea>
    </div>
    <div id="parse-preview"></div>
    <div style="display:flex;gap:8px;margin-top:.75rem;justify-content:flex-end;">
      <button class="btn btn-sm" onclick="clearAll()">CLEAR</button>
      <button class="btn btn-sm success" onclick="saveSnapshot()">SAVE SNAPSHOT</button>
