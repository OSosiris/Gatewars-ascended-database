        <div class="form-group"><label>spies killed</label><input type="text" id="f-spiesKilled" placeholder="0"></div>
        <div class="form-group"><label>spy killers killed</label><input type="text" id="f-spyKillersKilled" placeholder="0"></div>
        <div class="form-group"><label>MS weapons destroyed</label><input type="text" id="f-msWeaponsDestroyed" placeholder="0"></div>
        <div class="form-group"><label>MS shields destroyed</label><input type="text" id="f-msShieldsDestroyed" placeholder="0"></div>
