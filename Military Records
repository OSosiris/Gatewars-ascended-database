        <div class="form-group"><label>planets lost</label><input type="text" id="f-planetsLost" placeholder="0"></div>
        <div class="form-group"><label>naquadah lost</label><input type="text" id="f-naqLost" placeholder="0"></div>
        <div class="form-group"><label>untrained lost</label><input type="text" id="f-untrainedLost" placeholder="0"></div>
        <div class="form-group"><label>WP lost</label><input type="text" id="f-wpLost" placeholder="0"></div>
        <div class="form-group"><label>turns against you</label><input type="text" id="f-turnsAgainst" placeholder="0"></div>
      </div>
    </div>
  </details>
</div>
</div>

<div class="modal-bg" id="player-modal" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title" id="modal-player-name">PLAYER</span>
