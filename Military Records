  if(Object.keys(db.members).length<9){
    db={members:{},snapshots:{}};
    SEED.forEach(s=>{const{name,date,...rest}=s;
      db.members[name]={added:date};
      db.snapshots[name]=[{date,...rest}];
    });
    await saveData();
  }
