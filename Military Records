let parsedData={};

function parsePaste(){
  const raw=document.getElementById('paste-area').value;
  parsedData={};
  if(!raw.trim()){document.getElementById('parse-preview').innerHTML='';return;}
  raw.split('\n').forEach(line=>{
    const parts=line.split(/\t|  +/);
    if(parts.length<2)return;
    const label=parts[0].trim();
    const valStr=parts[parts.length-1].trim().replace(/,/g,'');
    const val=parseFloat(valStr);
    if(isNaN(val)||!label)return;
    for(const{pat,field}of FIELD_MAP){if(pat.test(label)){if(parsedData[field]===undefined)parsedData[field]=val;break;}}
  });
  const keys=Object.keys(parsedData);
  if(!keys.length){document.getElementById('parse-preview').innerHTML='<div class="parse-preview"><span style="color:var(--red)">Could not parse — copy the full ME table including labels and values.</span></div>';return;}
  keys.forEach(f=>{const el=document.getElementById('f-'+f);if(el)el.value=parsedData[f];});
  const hasWP=parsedData.warPoints!==undefined;
  let html=`<div class="parse-preview"><div style="color:var(--green);font-family:var(--head);font-weight:700;margin-bottom:6px;">PARSED ${keys.length} FIELDS ${hasWP?'':'— WARNING: WAR XP NOT FOUND'}</div>`;
  const priority=['warPoints','atkMercsKilled','defMercsKilled','atkSSKilled','defSSKilled','spiesKilled','spyKillersKilled','naqStolen','uuRaided','planetsTaken','naqLost'];
  const shown=new Set();
  [...priority,...keys].forEach(f=>{if(shown.has(f)||parsedData[f]===undefined)return;shown.add(f);html+=`<div class="parsed-field"><span class="pk">${FIELD_LABELS[f]||f}</span><span class="pv">${parsedData[f].toLocaleString()}</span></div>`;});
  html+='</div>';
  document.getElementById('parse-preview').innerHTML=html;
}

async function loadData(){
  try{const r=await window.storage.get(SK);if(r)db=JSON.parse(r.value);}catch(e){}
