function medalEl(i){if(i===0)return'<span class="rank-medal medal-1">1</span>';if(i===1)return'<span class="rank-medal medal-2">2</span>';if(i===2)return'<span class="rank-medal medal-3">3</span>';return`<span class="rank-medal medal-n">${i+1}</span>`;}
function nc(i){return i===0?'var(--gold)':i===1?'var(--silver)':i===2?'var(--bronze)':'#fff';}
function bc(i){return i===0?'#c89000':i===1?'#8090a0':i===2?'#8b5010':'#2a6eba';}

function renderWeekly(){
  const cat=document.getElementById('wk-category').value;
  const period=document.getElementById('wk-period').value;
  const names=Object.keys(db.members);
  if(!names.length){document.getElementById('wk-table-container').innerHTML='<div class="empty">NO MEMBERS YET</div>';return;}

  const rows=names.map(name=>{
    const snaps=db.snapshots[name]||[];
    const delta=getDelta(name,cat,period);
    return{name,delta:delta??0,hasData:snaps.length>=2,snaps:snaps.length};
  }).sort((a,b)=>{
    if(a.hasData!==b.hasData)return a.hasData?-1:1;
    return b.delta-a.delta;
  });

  const maxDelta=rows.filter(r=>r.hasData&&r.delta>0)[0]?.delta||1;

  const wMC=(i,r)=>{if(!r.hasData||r.delta<=0)return'medal-n';if(i===0)return'medal-0w';if(i===1)return'medal-1w';if(i===2)return'medal-2w';return'medal-n';};
  const wNC=(i,r)=>{if(!r.hasData||r.delta<=0)return'var(--text3)';if(i===0)return'var(--green)';if(i===1)return'var(--accent)';if(i===2)return'var(--bronze)';return'#fff';};
  const wBC=(i,r)=>{if(!r.hasData||r.delta<=0)return'#1a2330';if(i===0)return'#1a7a3a';if(i===1)return'#2a6eba';if(i===2)return'#8b5010';return'#2a6eba';};

  let html=`<table><thead><tr><th style="width:44px">#</th><th>PLAYER</th><th style="text-align:right">GAINED</th><th style="text-align:right;width:70px">STATUS</th><th style="width:80px;text-align:right">BAR</th></tr></thead><tbody>`;
  rows.forEach((r,i)=>{
    const active=r.hasData&&r.delta>0;
    const pct=active&&maxDelta?Math.round((r.delta/maxDelta)*100):0;
    const status=!r.hasData?'<span class="inactive-badge">NO DATA</span>':r.delta<=0?'<span class="inactive-badge">INACTIVE</span>':'<span class="active-badge">ACTIVE</span>';
    const rank=active?`<span class="rank-medal ${wMC(i,r)}">${i+1}</span>`:'<span class="rank-medal medal-n">—</span>';
    const deltaStr=active?`<span style="color:var(--green)">${fmtD(r.delta)}</span>`:'<span style="color:var(--text3)">—</span>';
    html+=`<tr class="data-row" onclick="openPlayerModal('${safeN(r.name)}')"><td>${rank}</td><td style="color:${wNC(i,r)};font-weight:700;">${r.name}</td><td class="num">${deltaStr}</td><td style="text-align:right;">${status}</td><td><div class="progress-wrap"><div class="progress-fill" style="width:${pct}%;background:${wBC(i,r)};"></div></div><div style="text-align:right;font-size:10px;color:var(--text3);margin-top:2px;">${pct>0?pct+'%':''}</div></td></tr>`;
  });
  html+='</tbody></table>';
  document.getElementById('wk-table-container').innerHTML=html;

  let totXP=0,totK=0,totR=0,totN=0;
  names.forEach(name=>{totXP+=Math.max(0,getDelta(name,'warPoints',period)||0);totK+=Math.max(0,getDelta(name,'totalKilled',period)||0);totR+=Math.max(0,getDelta(name,'totalRaided',period)||0);totN+=Math.max(0,getDelta(name,'naqStolen',period)||0);});
  document.getElementById('wk-totals').innerHTML=`<div class="metric"><div class="mlabel">XP GAINED</div><div class="mvalue" style="color:var(--green)">${fmt(totXP)}</div></div><div class="metric"><div class="mlabel">UNITS KILLED</div><div class="mvalue">${fmt(totK)}</div></div><div class="metric"><div class="mlabel">UNITS RAIDED</div><div class="mvalue">${fmt(totR)}</div></div><div class="metric"><div class="mlabel">NAQ STOLEN</div><div class="mvalue">${fmt(totN)}</div></div>`;
}

function renderLeaderboard(){
  const cat=document.getElementById('lb-category').value;
  const names=Object.keys(db.members);
  if(!names.length){document.getElementById('lb-table-container').innerHTML='<div class="empty">NO MEMBERS YET</div>';return;}
  const rows=names.map(name=>{const s=computed(getLatest(name));return{name,val:p(s[cat]||0)};}).sort((a,b)=>b.val-a.val);
  const maxVal=rows[0]?.val||1;
  document.getElementById('lb-table-container').innerHTML=`<table><thead><tr><th style="width:44px">#</th><th>PLAYER</th><th style="text-align:right">${CATS[cat]?.label||cat}</th><th style="width:80px;text-align:right">%</th></tr></thead><tbody>${rows.map((r,i)=>{const pct=maxVal?Math.round((r.val/maxVal)*100):0;return`<tr class="data-row" onclick="openPlayerModal('${safeN(r.name)}')"><td>${medalEl(i)}</td><td style="color:${nc(i)};font-weight:700;">${r.name}</td><td class="num">${fmt(r.val)}</td><td><div class="progress-wrap"><div class="progress-fill" style="width:${pct}%;background:${bc(i)};"></div></div><div style="text-align:right;font-size:10px;color:var(--text3);margin-top:2px;">${pct}%</div></td></tr>`;}).join('')}</tbody></table>`;
  let totWP=0,totK=0,totR=0,totN=0;
  names.forEach(name=>{const s=computed(getLatest(name));totWP+=p(s.warPoints);totK+=p(s.totalKilled);totR+=p(s.totalRaided);totN+=p(s.naqStolen);});
  document.getElementById('alliance-totals').innerHTML=`<div class="metric"><div class="mlabel">TOTAL WAR XP</div><div class="mvalue" style="color:var(--gold)">${fmt(totWP)}</div></div><div class="metric"><div class="mlabel">UNITS KILLED</div><div class="mvalue">${fmt(totK)}</div></div><div class="metric"><div class="mlabel">UNITS RAIDED</div><div class="mvalue">${fmt(totR)}</div></div><div class="metric"><div class="mlabel">NAQ STOLEN</div><div class="mvalue">${fmt(totN)}</div></div>`;
}

function renderMembers(){
  const q=document.getElementById('member-search').value.toLowerCase();
  const names=Object.keys(db.members).filter(n=>n.toLowerCase().includes(q));
  if(!names.length){document.getElementById('members-list').innerHTML='<div class="empty">NO MEMBERS FOUND</div>';return;}
  const ranked=getRanked();const rankMap={};ranked.forEach((r,i)=>rankMap[r.name]=i);
  document.getElementById('members-list').innerHTML=names.map(name=>{
    const snaps=db.snapshots[name]||[];const latest=computed(getLatest(name));const prev=snaps.length>1?computed(snaps[snaps.length-2]):null;
    const delta=prev?(p(latest.warPoints)-p(prev.warPoints)):null;const ri=rankMap[name]??99;
    const icon=ri===0?'🥇':ri===1?'🥈':ri===2?'🥉':`<span style="font-size:13px;color:var(--text3);font-family:var(--head);font-weight:700;">#${ri+1}</span>`;
    return`<div class="card" style="margin-bottom:8px;cursor:pointer;" onclick="openPlayerModal('${safeN(name)}')"><div style="display:flex;align-items:center;justify-content:space-between;"><div style="display:flex;align-items:center;gap:12px;"><div style="font-size:20px;line-height:1;min-width:28px;text-align:center;">${icon}</div><div><div style="font-weight:700;font-size:15px;color:${nc(ri)};font-family:var(--head);">${name}</div><div style="font-size:11px;color:var(--text3);font-family:var(--head);">${snaps.length} SNAPSHOT${snaps.length===1?'':'S'} · ${snaps[snaps.length-1]?.date||'—'}</div></div></div><div style="text-align:right;"><div style="font-size:14px;font-weight:700;color:var(--accent);font-family:var(--head);">${fmt(latest.warPoints)} XP</div>${delta!==null?`<div class="${delta>=0?'delta-pos':'delta-neg'}">${fmtD(delta)} this period</div>`:''}</div></div></div>`;
  }).join('');
}

function openPlayerModal(name){
  const snaps=db.snapshots[name]||[];const latest=computed(getLatest(name));const prev=snaps.length>1?computed(snaps[snaps.length-2]):null;
  const ranked=getRanked();const ri=ranked.findIndex(r=>r.name===name);
  const medal=ri===0?'🥇':ri===1?'🥈':ri===2?'🥉':'#'+(ri+1);
  document.getElementById('modal-player-name').textContent=`${medal} ${name}`;
  const drow=(label,key)=>{const cur=p(latest[key]||0);const d=prev?(cur-p(prev[key]||0)):null;return`<tr><td style="color:var(--text2)">${label}</td><td class="num">${fmt(cur)}</td><td style="text-align:right;font-size:11px;" class="${d===null?'':d>0?'delta-pos':d<0?'delta-neg':''}">${d===null?'':(d>=0?'+':'')+fmt(d)}</td></tr>`;};
  const histRows=[...snaps].reverse().slice(0,8).map((s,i,arr)=>{const p2=arr[i+1];const d=p2?(p(s.warPoints)-p(p2.warPoints)):null;return`<div class="snap-row"><span style="color:var(--text3)">${s.date}</span><span style="display:flex;gap:12px;align-items:center;"><span style="color:var(--accent);font-family:var(--head);font-weight:700;">${fmt(s.warPoints)} XP</span>${d!==null?`<span class="${d>=0?'delta-pos':'delta-neg'}">${fmtD(d)}</span>`:''}</span></div>`;}).join('');
  document.getElementById('modal-content').innerHTML=`
    <div class="grid3" style="margin-bottom:1.25rem;">
      <div class="metric"><div class="mlabel">WAR XP</div><div class="mvalue" style="color:var(--gold)">${fmt(latest.warPoints)}</div></div>
      <div class="metric"><div class="mlabel">TOTAL KILLED</div><div class="mvalue">${fmt(latest.totalKilled)}</div></div>
      <div class="metric"><div class="mlabel">TOTAL RAIDED</div><div class="mvalue">${fmt(latest.totalRaided)}</div></div>
    </div>
    <p class="section-title">kills vs last snapshot</p>
    <table style="margin-bottom:1.25rem;"><thead><tr><th>STAT</th><th style="text-align:right">CURRENT</th><th style="text-align:right">CHANGE</th></tr></thead><tbody>
      ${drow('TOTAL KILLED','totalKilled')}${drow('ATK MERCS KILLED','atkMercsKilled')}${drow('DEF MERCS KILLED','defMercsKilled')}${drow('ATK SS KILLED','atkSSKilled')}${drow('DEF SS KILLED','defSSKilled')}${drow('SPIES KILLED','spiesKilled')}${drow('SPY KILLERS KILLED','spyKillersKilled')}
    </tbody></table>
    <p class="section-title">raids and economy vs last snapshot</p>
    <table style="margin-bottom:1.25rem;"><thead><tr><th>STAT</th><th style="text-align:right">CURRENT</th><th style="text-align:right">CHANGE</th></tr></thead><tbody>
      ${drow('TOTAL RAIDED (UU)','totalRaided')}${drow('NAQ STOLEN','naqStolen')}${drow('PLANETS TAKEN','planetsTaken')}${drow('WP DESTROYED','wpDestroyed')}
    </tbody></table>
    <p class="section-title">losses vs last snapshot</p>
    <table style="margin-bottom:1.25rem;"><thead><tr><th>STAT</th><th style="text-align:right">CURRENT</th><th style="text-align:right">CHANGE</th></tr></thead><tbody>
      ${drow('NAQ LOST','naqLost')}${drow('PLANETS LOST','planetsLost')}
    </tbody></table>
    <p class="section-title">snapshot history</p>
    <div style="margin-bottom:1rem;">${histRows||'<div class="empty" style="padding:1rem">NO HISTORY YET</div>'}</div>
    <hr class="divider">
    <div style="display:flex;gap:8px;justify-content:space-between;flex-wrap:wrap;">
      <button class="btn btn-sm" onclick="prefillUpdate('${safeN(name)}')">UPDATE ME</button>
      <button class="btn btn-sm danger" onclick="deleteMember('${safeN(name)}')">DELETE PLAYER</button>
    </div>`;
  document.getElementById('player-modal').classList.add('open');
}

function prefillUpdate(name){
  document.getElementById('player-modal').classList.remove('open');
  switchTab('add');
  document.getElementById('f-name').value=name;
  document.getElementById('f-date').value=new Date().toISOString().split('T')[0];
  document.getElementById('paste-area').value='';
  document.getElementById('parse-preview').innerHTML='';
  parsedData={};
}

async function deleteMember(name){if(!confirm('Delete '+name+' and all snapshots?'))return;delete db.members[name];delete db.snapshots[name];await saveData();document.getElementById('player-modal').classList.remove('open');updateMemberCount();renderWeekly();renderMembers();renderLeaderboard();}

function clearAll(){
  document.getElementById('paste-area').value='';document.getElementById('parse-preview').innerHTML='';parsedData={};
  ['f-name','f-atkMercsKilled','f-defMercsKilled','f-atkSoldiersKilled','f-defSoldiersKilled','f-atkSSKilled','f-defSSKilled','f-spiesKilled','f-spyKillersKilled','f-msWeaponsDestroyed','f-msShieldsDestroyed','f-msFleetsDestroyed','f-planetDefDestroyed','f-planetsTaken','f-naqStolen','f-uuRaided','f-wpDestroyed','f-attackTurns','f-warPoints','f-atkMercsLost','f-defMercsLost','f-raidersLost','f-guardsLost','f-ssLost','f-sgLost','f-uaLost','f-assLost','f-msWeaponsLost','f-msShieldsLost','f-msFleetsLost','f-planetDefLost','f-planetsLost','f-naqLost','f-untrainedLost','f-wpLost','f-turnsAgainst'].forEach(id=>{const el=document.getElementById(id);if(el&&el.type!=='date')el.value='';});
  document.getElementById('save-status').textContent='';
}

async function saveSnapshot(){
  const name=document.getElementById('f-name').value.trim();
  const date=document.getElementById('f-date').value;
  if(!name){document.getElementById('save-status').innerHTML='<span style="color:var(--red)">PLAYER NAME REQUIRED</span>';return;}
  if(!date){document.getElementById('save-status').innerHTML='<span style="color:var(--red)">DATE REQUIRED</span>';return;}
  const fieldNames=['atkMercsKilled','defMercsKilled','atkSoldiersKilled','defSoldiersKilled','atkSSKilled','defSSKilled','spiesKilled','spyKillersKilled','msWeaponsDestroyed','msShieldsDestroyed','msFleetsDestroyed','planetDefDestroyed','planetsTaken','naqStolen','uuRaided','wpDestroyed','attackTurns','warPoints','atkMercsLost','defMercsLost','raidersLost','guardsLost','ssLost','sgLost','uaLost','assLost','msWeaponsLost','msShieldsLost','msFleetsLost','planetDefLost','planetsLost','naqLost','untrainedLost','wpLost','turnsAgainst'];
  const snap={date};
  fieldNames.forEach(f=>{snap[f]=parsedData[f]!==undefined?parsedData[f]:nv('f-'+f);});
  if(!db.members[name])db.members[name]={added:date};
  if(!db.snapshots[name])db.snapshots[name]=[];
  const idx=db.snapshots[name].findIndex(s=>s.date===date);
  if(idx>=0)db.snapshots[name][idx]=snap;else{db.snapshots[name].push(snap);db.snapshots[name].sort((a,b)=>a.date.localeCompare(b.date));}
  await saveData();
  document.getElementById('save-status').innerHTML=`<span style="color:var(--green)">SAVED — ${name} / ${date}</span>`;
  updateMemberCount();renderWeekly();renderLeaderboard();renderMembers();
}

function openSettings(){document.getElementById('s-alliance-name').value=settings.allianceName;document.getElementById('settings-modal').classList.add('open');}
async function saveSettings(){settings.allianceName=document.getElementById('s-alliance-name').value.trim()||'THE RELENTLESS';try{await window.storage.set(SK2,JSON.stringify(settings));}catch(e){}document.getElementById('alliance-name-display').textContent=settings.allianceName;document.getElementById('settings-modal').classList.remove('open');}

loadData();
</script>
